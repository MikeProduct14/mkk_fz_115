# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Dadata API Key
# Get your key from https://dadata.ru
# Used for organization data autofill by INN
DADATA_API_KEY=your_dadata_key_here

# NewDB API Key
# Get your key from https://newdb.net
# Used for RFM and passport checks
NEWDB_API_KEY=your_newdb_key_here
